<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@<%= perfil.username %> — MicroBlog</title>
    <link rel="stylesheet" href="/style.css">
    <script>
        (function () {
            const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
</head>
<body>
    <header class="navbar">
        <a href="/" class="logo">MicroBlog</a>
        <nav>
            <button class="theme-toggle-btn" id="themeToggle" title="Alternar Tema">
                <svg id="themeIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></svg>
            </button>
            <a href="/perfil/<%= usuario.username %>">@<%= usuario.username %></a>
            <a href="/logout" class="btn-sair">Sair</a>
        </nav>
    </header>

    <main class="container">
        <a href="/" class="btn-voltar">← Voltar ao feed</a>

        <section class="card-perfil">
            <h2><%= perfil.nome %></h2>
            <p class="username-grande">@<%= perfil.username %></p>
            <% if (perfil.bio) { %>
                <p class="bio"><%= perfil.bio %></p>
            <% } %>
            <p class="data-cadastro">Membro desde <%= new Date(perfil.dataCadastro).toLocaleDateString('pt-BR') %></p>
            <p class="contador-posts"><strong><%= posts.length %></strong> post(s)</p>
        </section>

        <section class="lista-posts">
            <h3>Posts de @<%= perfil.username %></h3>

            <% if (posts.length === 0) { %>
                <p class="vazio">Este usuário ainda não publicou nada.</p>
            <% } else { %>
                <% posts.forEach(post => { %>
                    <article class="card-post">
                        <div class="post-cabecalho">
                            <span class="data"><%= new Date(post.dataCriacao).toLocaleString('pt-BR') %></span>
                        </div>

                        <p class="post-conteudo"><%= post.conteudo %></p>

                        <% if (post.hashtags && post.hashtags.length > 0) { %>
                            <div class="hashtags">
                                <% post.hashtags.forEach(h => { %>
                                    <span class="hashtag"><%= h %></span>
                                <% }) %>
                            </div>
                        <% } %>

                        <div class="post-acoes">
                            <a href="/posts/<%= post._id %>" class="btn-link">Comentários</a>
                            <% if (String(post.autorId) === usuario.userId) { %>
                                <div class="botoes-autor">
                                    <a href="/posts/<%= post._id %>/editar" class="btn-editar" title="Editar Post">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
                                    </a>
                                    <form method="POST" action="/posts/<%= post._id %>/deletar" class="form-inline">
                                        <button type="submit" class="btn-lixeira" title="Deletar Post"
                                            onclick="return confirm('Deletar este post?')">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                        </button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    </article>
                <% }) %>
            <% } %>
        </section>
    </main>

    <script>
        const toggleBtn = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');
        const sunSVG = `<circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>`;
        const moonSVG = `<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>`;

        function updateThemeUI(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            if (theme === 'dark') {
                themeIcon.innerHTML = sunSVG;
            } else {
                themeIcon.innerHTML = moonSVG;
            }
        }

        const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
        updateThemeUI(currentTheme);

        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                const activeTheme = document.documentElement.getAttribute('data-theme');
                const newTheme = activeTheme === 'dark' ? 'light' : 'dark';
                localStorage.setItem('theme', newTheme);
                updateThemeUI(newTheme);
            });
        }
    </script>
</body>
</html>
