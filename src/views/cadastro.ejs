<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro — MicroBlog</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="pagina-auth">
    <div class="card-auth">
        <h1 class="logo">MicroBlog</h1>
        <h2>Criar conta</h2>

        <% if (erro) { %>
            <p class="mensagem-erro"><%= erro %></p>
        <% } %>

        <form method="POST" action="/cadastro">
            <div class="campo">
                <label for="nome">Nome completo <span class="obrigatorio">*</span></label>
                <input type="text" id="nome" name="nome" required placeholder="Seu nome">
            </div>
            <div class="campo">
                <label for="username">Username <span class="obrigatorio">*</span></label>
                <input type="text" id="username" name="username" required placeholder="seunome">
            </div>
            <div class="campo">
                <label for="email">E-mail <span class="obrigatorio">*</span></label>
                <input type="email" id="email" name="email" required placeholder="seu@email.com">
            </div>
            <div class="campo">
                <label for="senha">Senha <span class="obrigatorio">*</span></label>
                <input type="password" id="senha" name="senha" required placeholder="••••••••">
            </div>
            <div class="campo">
                <label for="bio">Bio <span class="opcional">(opcional)</span></label>
                <input type="text" id="bio" name="bio" placeholder="Fale um pouco sobre você">
            </div>
            <button type="submit" class="btn-primario">Criar conta</button>
        </form>

        <p class="link-alternativo">Já tem conta? <a href="/login">Entrar</a></p>
    </div>
</body>
</html>
